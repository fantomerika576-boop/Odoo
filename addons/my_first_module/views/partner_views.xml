<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_my_partner_tree" model="ir.ui.view">
        <field name="name">my.partner.tree</field>
        <field name="model">my.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <record id="view_my_partner_form" model="ir.ui.view">
        <field name="name">my.partner.form</field>
        <field name="model">my.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="phone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_my_partner" model="ir.actions.act_window">
        <field name="name">My Partners</field>
        <field name="res_model">my.partner</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_my_partner_root"
              name="My Module"/>

    <menuitem id="menu_my_partner"
              name="Partners"
              parent="menu_my_partner_root"
              action="action_my_partner"/>

</odoo>