<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_birthday_greeting" model="ir.cron">
        <field name="name">Поздравления с Днём Рождения (ежедневно)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_birthday_greetings()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_stock_reorder_check" model="ir.cron">
        <field name="name">Проверка остатков и автозакупка (ежедневно)</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_stock_and_reorder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
