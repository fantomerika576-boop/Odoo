<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_reorder" model="ir.ui.view">
        <field name="name">product.template.form.reorder</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='general_information']" position="inside">
                <group string="Автозакупка (пример)">
                    <field name="custom_reorder_min"/>
                    <field name="custom_reorder_qty"/>
                </group>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_check_and_create_po" type="object"
                        string="Проверить остаток и заказать" class="oe_stat_button"
                        icon="fa-shopping-cart"/>
            </xpath>
        </field>
    </record>
</odoo>
